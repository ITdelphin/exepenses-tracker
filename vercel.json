{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/backend/src/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/index.html",
            "permanent": false
        }
    ]
}